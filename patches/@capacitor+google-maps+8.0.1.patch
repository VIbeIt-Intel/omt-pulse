+            val map = maps[id]
+            map ?: throw MapNotFoundError()
+
+            val tilt = if (call.data.has("tiltGestures")) call.getBoolean("tiltGestures") else null
+            val rotate = if (call.data.has("rotateGestures")) call.getBoolean("rotateGestures") else null
+            val zoom = if (call.data.has("zoomGestures")) call.getBoolean("zoomGestures") else null
+            val scroll = if (call.data.has("scrollGestures")) call.getBoolean("scrollGestures") else null
+
+            map.setGestures(tilt, rotate, zoom, scroll) { err ->
+                if (err != null) {
+                    handleError(call, err)
+                } else {
+                    call.resolve()
+                }
+            }
+        } catch (e: GoogleMapsError) {
+            handleError(call, e)
+        } catch (e: Exception) {
+            handleError(call, e)
+        }
+    }
