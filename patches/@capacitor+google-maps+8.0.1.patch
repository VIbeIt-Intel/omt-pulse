+                    if (rotateGestures != null) ui.isRotateGesturesEnabled = rotateGestures
+                    if (zoomGestures != null) ui.isZoomGesturesEnabled = zoomGestures
+                    if (scrollGestures != null) ui.isScrollGesturesEnabled = scrollGestures
