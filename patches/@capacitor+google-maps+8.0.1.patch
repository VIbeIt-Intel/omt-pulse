+    // OMT patch: per-gesture lock so nav mode can disable tilt+rotate gestures
+    // (which trigger the SDK's gesture-settle deceleration and flatten tilt
+    // back to 0 after every camera move). Any field may be omitted to leave
+    // the current setting untouched.
+    @PluginMethod
+    fun setGestures(call: PluginCall) {
+        try {
+            val id = call.getString("id")
