# Production environment for VPS / self-hosted deploy
# Copy to /opt/omt-pulse/.env and chmod 600

NODE_ENV=production
PORT=5000

# ── Required ──────────────────────────────────────────────────────────────────
# PostgreSQL connection (migrate from Replit or use Neon/Supabase/RDS)
DATABASE_URL=postgresql://user:password@localhost:5432/omt_pulse

# Generate: openssl rand -base64 48
SESSION_SECRET=

# Public URL (used in invite links, OG tags, client build)
APP_BASE_URL=https://omtpulse.com
VITE_APP_BASE_URL=https://omtpulse.com

# Browser key from Firebase/GCP (baked into client at npm run build)
VITE_GOOGLE_MAPS_API_KEY=

# Optional Play Store link on marketing page
# VITE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.intelafri.omtpulse
# Closed testing opt-in — auto-included in User Admin “copy tester message”
# VITE_PLAY_TESTING_JOIN_URL=https://play.google.com/apps/testing/com.intelafri.omtpulse

# ── Google Cloud Storage (uploads, custom map images) ───────────────────────
# Service account JSON path OR run on GCE with attached service account
GOOGLE_APPLICATION_CREDENTIALS=/opt/omt-pulse/secrets/gcs-service-account.json

# Format: /bucket-name/private  and  /bucket-name/public
PRIVATE_OBJECT_DIR=/your-gcs-bucket/private
PUBLIC_OBJECT_SEARCH_PATHS=/your-gcs-bucket/public

# ── Web push (optional) ───────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:sales@intelafri.org

# ── FCM native Android/iOS push (optional) ────────────────────────────────────
# Preferred: service account JSON file (same pattern as GCS credentials)
FIREBASE_SERVICE_ACCOUNT_PATH=/opt/omt-pulse/secrets/firebase-service-account.json
# Alternative: inline JSON (private_key must preserve \n newlines)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Admin / email (optional) ──────────────────────────────────────────────────
ARCHON_PASSWORD=
# Resend.com — free tier suitable for invite + contact emails
RESEND_API_KEY=
# Must use a Resend-verified domain (e.g. intelafri-imt.co.za). Quote if using display name.
RESEND_FROM_EMAIL="OMT Pulse <sales@intelafri-imt.co.za>"

# ── Vehicle GPS trackers (GT06 / OBD) ─────────────────────────────────────────
# TCP listener starts with the app; open this port on the VPS firewall.
VEHICLE_TRACKER_TCP_ENABLED=true
VEHICLE_TRACKER_TCP_PORT=7711
VEHICLE_TRACKER_TCP_HOST=0.0.0.0
