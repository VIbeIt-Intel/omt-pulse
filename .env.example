# OMT Pulse environment variables
# Copy to .env for local dev (Vite reads VITE_* at dev/build time).

# ── Google Maps — Firebase uses TWO separate keys (GCP → Credentials) ─────────
#
# Browser key (auto created by Firebase):
#   → VITE_GOOGLE_MAPS_API_KEY (WebView JS API: Map View, geocoding, directions)
#
# Android key (auto created by Firebase):
#   → Native map tiles via google-services.json (auto) or GOOGLE_MAPS_ANDROID_API_KEY override
#   → Do NOT put the Browser key in the Android manifest

# Web / Capacitor WebView (Maps JavaScript API):
VITE_GOOGLE_MAPS_API_KEY=

# Optional: Google Play listing URL (shows on landing page when set)
# VITE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.intelafri.omtpulse

# Optional override for native Android (normally read from android/app/google-services.json):
GOOGLE_MAPS_ANDROID_API_KEY=

# ── Google Cloud Console — project: intelafri-omtpulse ────────────────────────
#
# 1. Enable APIs:
#    Maps SDK for Android, Maps JavaScript API, Directions, Places, Geocoding
#    Billing must be active.
#
# 2. Edit "Android key (auto created by Firebase)" → Application restrictions → Android apps:
#    Package: com.intelafri.omtpulse
#    Add SHA-1 fingerprints for ALL signing certificates:
#
#    a) Play App Signing key (Play Console → Setup → App integrity → App signing)
#    b) Upload/release keystore (printed in GitHub Actions build log)
#    c) Debug keystore (local dev): ~/.android/debug.keystore / androiddebugkey
#
# 3. Edit "Browser key (auto created by Firebase)" for WebView JS API:
#    Either Android app restriction (same package + SHA-1s), OR HTTP referrers:
#    https://localhost/*  and  https://omtpulse.com/*
#
# ── GitHub Actions secrets ────────────────────────────────────────────────────
# VITE_GOOGLE_MAPS_API_KEY     — Browser key (required for npm run build)
# GOOGLE_MAPS_ANDROID_API_KEY  — optional; defaults to google-services.json
# KEYSTORE_BASE64, KEYSTORE_PASSWORD, KEY_ALIAS, KEY_PASSWORD — release signing
#
# ── Server ────────────────────────────────────────────────────────────────────
DATABASE_URL=
SESSION_SECRET=
PORT=5000

# Optional: push notifications (web/PWA)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:sales@intelafri.org

# Optional: FCM native Android/iOS push — file path (preferred) or inline JSON
# FIREBASE_SERVICE_ACCOUNT_PATH=secrets/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: object storage for uploads / custom map images
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=
